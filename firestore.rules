rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && (
          request.auth.token.email == "ap4839@columbia.edu"
          || request.auth.token.email == "pallaviputcha@gmail.com"
          || exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        );
    }

    function isOwnRsvp(uid) {
      return signedIn()
        && request.auth.uid == uid
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.guestName is string
        && request.resource.data.guestEmail is string
        && request.resource.data.attendance in ["yes", "no", "maybe"]
        && request.resource.data.partySize is int
        && request.resource.data.partySize == 1;
    }

    match /admins/{uid} {
      allow get: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /rsvps/{uid} {
      allow get: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow list: if isAdmin();
      allow create, update: if isOwnRsvp(uid);
      allow delete: if isAdmin();
    }

    match /uploads/{uploadId} {
      allow create: if signedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.storagePath.matches("eventUploads/" + request.auth.uid + "/.*")
        && request.resource.data.originalName is string
        && request.resource.data.size is int
        && request.resource.data.size > 0;
      allow get, list, update, delete: if isAdmin();
    }

    match /playlistSongs/{songId} {
      allow get, list: if true;
      allow create: if signedIn()
        && request.resource.data.addedByUid == request.auth.uid
        && request.resource.data.spotifyUrl is string
        && request.resource.data.spotifyUrl.matches("https://open\\.spotify\\.com/track/.*")
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 200;
      allow update, delete: if isAdmin();
    }
  }
}
